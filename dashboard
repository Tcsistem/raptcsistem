function esportaDettaglioCSV(){if(!rapCorrente)return;var r=rapCorrente;var lines=[csvRow('RAPPORTINO N.'+(r.numero||''),'Data',r.data||''),csvRow('Cliente',r.cliente||'','Commessa',r.commessa||''),csvRow('Tecnico',r.tecnico||'','Tipo',r.tipo||''),csvRow('Indirizzo',r.indirizzo||'','Avanzamento',(parseInt(r.stato)||0)+'%'),csvRow('Descrizione',r.descrizione||''),csvRow(''),csvRow('MATERIALI'),csvRow('Materiale','Qty','Unità')];(r.materiali||[]).forEach(function(m){lines.push(csvRow(m.desc,m.qty,m.unit))});lines.push(csvRow(''),csvRow('OPERAI E ORE'),csvRow('Operaio','Lav.','Viag.','Str.'));(r.operai||[]).forEach(function(o){lines.push(csvRow(o.nome,fmt(o.oreLav),fmt(o.oreViag),fmt(o.oreStr)))});lines.push(csvRow(''),csvRow('Totale lavoro',fmt(r.totLav||0),'Viaggio',fmt(r.totViag||0),'Straord.',fmt(r.totStr||0)),csvRow(''),csvRow('Note',r.note||''));scarica(lines.join('\n'),(r.numero||'rapportino')+'.csv');}
function scarica(contenuto,nome){var b=new Blob(['\uFEFF'+contenuto],{type:'text/csv;charset=utf-8'});var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=nome;document.body.appendChild(a);a.click();document.body.removeChild(a)}


// ── REINDEX ──────────────────────────────────────────────────────────
async function reindex() {
  if(!confirm('Ricostruire indice leggendo tutti i file su Drive? Potrebbe richiedere qualche secondo.')) return;
  el('conn-dot').className = 'conn-dot spin';
  el('conn-lbl').textContent = 'Ricostruzione indice...';
  try {
    var res = await fetch(SCRIPT_URL + '?action=reindex&_dc=' + Date.now());
    var d = await res.json();
    if(d.ok) {
      showAlert('✓ ' + d.msg, 'ok');
      caricaDati();
    } else {
      showAlert('Errore: ' + (d.error||''), 'err');
    }
  } catch(e) {
    showAlert('Errore: ' + e.message, 'err');
  }
}

// ── GESTIONE OPERAI ──────────────────────────────────────────────────
var operaiLista = [];

async function apriGestioneOperai() {
  document.getElementById('operai-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
  await caricaOperai();
}

function chiudiGestioneOperai() {
  document.getElementById('operai-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

async function caricaOperai() {
  try {
    var res = await fetch(SCRIPT_URL + '?action=operai&_dc=' + Date.now());
    var d = await res.json();
    if(d.ok) { operaiLista = d.operai || []; renderOperai(); }
  } catch(e) {
    document.getElementById('operai-lista').innerHTML = '<div style="color:#c0392b;font-size:13px">Errore caricamento</div>';
  }
}

function renderOperai() {
  var w = document.getElementById('operai-lista');
  if(!operaiLista.length) {
    w.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text3);font-size:13px">Nessun operaio inserito</div>';
    return;
  }
  w.innerHTML = operaiLista.map(function(nome, i) {
    return '<div class="operaio-item"><span style="font-weight:500">' + esc(nome) + '</span>' +
      '<button class="operaio-del" onclick="rimuoviOperaio(' + i + ')">✕</button></div>';
  }).join('');
}

function aggiungiOperaio() {
  var input = document.getElementById('nuovo-operaio');
  var nome = (input.value || '').trim().toUpperCase();
  if(!nome) return;
  if(operaiLista.includes(nome)) { alert('Operaio già presente!'); return; }
  operaiLista.push(nome);
  operaiLista.sort();
  input.value = '';
  renderOperai();
  input.focus();
}

function rimuoviOperaio(i) {
  if(!confirm('Rimuovere "' + operaiLista[i] + '"?')) return;
  operaiLista.splice(i, 1);
  renderOperai();
}

async function salvaOperai() {
  try {
    var res = await fetch(SCRIPT_URL, {
      method: 'POST',
      headers: {'Content-Type': 'text/plain'},
      body: JSON.stringify({_action: 'saveOperai', operai: operaiLista})
    });
    var d = await res.json();
    if(d.ok) { showAlert('\u2713 Lista operai salvata!', 'ok'); }
    else { showAlert('Errore: ' + (d.error||''), 'err'); }
  } catch(e) {
    showAlert('Errore: ' + e.message, 'err');
  }
}


// ── MODIFICA RAPPORTINO ──────────────────────────────────────────
var modOperai = [];

function apriModificaModale() {
  if (!rapCorrente) return;
  var r = rapCorrente;
  // Popola campi
  el('mod-f-num').value = r.numero || '';
  el('mod-f-data').value = r.data || '';
  el('mod-f-cliente').value = r.cliente || '';
  el('mod-f-commessa').value = r.commessa || '';
  el('mod-f-indirizzo').value = r.indirizzo || '';
  el('mod-f-tecnico').value = r.tecnico || '';
  el('mod-f-tipo').value = r.tipo || '';
  el('mod-f-stato').value = r.stato || '0';
  el('mod-f-desc').value = r.descrizione || '';
  el('mod-f-note').value = r.note || '';
  modOperai = (r.operai || []).map(function(o) { return Object.assign({}, o); });
  renderModOperai();
  popolaSelectModOperai();
  el('modifica-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function chiudiModifica() {
  el('modifica-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

function popolaSelectModOperai() {
  // Carica lista operai dal server
  fetch(SCRIPT_URL + '?action=operai&_dc=' + Date.now())
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.ok) return;
      var sel = el('mod-op-nome');
      var val = sel.value;
      sel.innerHTML = '<option value="">Seleziona operaio...</option>';
      (d.operai || []).forEach(function(nome) {
        var opt = document.createElement('option');
        opt.value = nome;
        opt.textContent = nome;
        sel.appendChild(opt);
      });
      if (val) sel.value = val;
    }).catch(function() {});
}

function renderModOperai() {
  var w = el('mod-operai-lista');
  if (!modOperai.length) {
    w.innerHTML = '<div style="font-size:13px;color:var(--text3);padding:8px 0">Nessun operaio</div>';
    return;
  }
  w.innerHTML = modOperai.map(function(o, i) {
    return '<div class="mod-op-row">' +
      '<span style="flex:1;font-size:13px;font-weight:500">' + esc(o.nome) + '</span>' +
      '<span style="font-size:12px;color:var(--text2);margin-right:8px">Lav: ' + (o.oreLav||0) + 'h · Viag: ' + (o.oreViag||0) + 'h · Str: ' + (o.oreStr||0) + 'h</span>' +
      '<button class="operaio-del" onclick="modRmOp(' + i + ')">✕</button>' +
    '</div>';
  }).join('');
}

function modAddOp() {
  var sel = el('mod-op-nome');
  var nome = sel ? sel.value : '';
  if (!nome) return;
  var lav = parseFloat(el('mod-op-lav').value) || 0;
  var viag = parseFloat(el('mod-op-viag').value) || 0;
  var str = parseFloat(el('mod-op-str').value) || 0;
  modOperai.push({ nome: nome, oreLav: lav, oreViag: viag, oreStr: str });
  if (sel) sel.selectedIndex = 0;
  el('mod-op-lav').value = '';
  el('mod-op-viag').value = '';
  el('mod-op-str').value = '';
  renderModOperai();
}

function modRmOp(i) {
  modOperai.splice(i, 1);
  renderModOperai();
}

async function salvaModifica() {
  if (!rapCorrente) return;
  var r = Object.assign({}, rapCorrente);
  r.numero = el('mod-f-num').value;
  r.data = el('mod-f-data').value;
  r.cliente = el('mod-f-cliente').value;
  r.commessa = el('mod-f-commessa').value;
  r.indirizzo = el('mod-f-indirizzo').value;
  r.tecnico = (el('mod-f-tecnico').value || '').toUpperCase();
  r.tipo = el('mod-f-tipo').value;
  r.stato = el('mod-f-stato').value;
  r.descrizione = el('mod-f-desc').value;
  r.note = el('mod-f-note').value;
  r.operai = modOperai;
  r.totLav = modOperai.reduce(function(s, o) { return s + (parseFloat(o.oreLav) || 0); }, 0);
  r.totViag = modOperai.reduce(function(s, o) { return s + (parseFloat(o.oreViag) || 0); }, 0);
  r.totStr = modOperai.reduce(function(s, o) { return s + (parseFloat(o.oreStr) || 0); }, 0);

  try {
    var res = await fetch(SCRIPT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain' },
      body: JSON.stringify(r)
    });
    var d = await res.json();
    if (d.ok) {
      showAlert('✓ Rapportino aggiornato su Drive!', 'ok');
      rapCorrente = r;
      chiudiModifica();
      caricaDati(); // ricarica lista
    } else {
      showAlert('Errore: ' + (d.error || ''), 'err');
    }
  } catch(e) {
    showAlert('Errore: ' + e.message, 'err');
  }
}

