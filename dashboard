<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard TC Sistem</title>
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');
:root{--bg:#f5f4f0;--surface:#fff;--surface2:#f0efe9;--surface3:#e8e7e0;--border:#e0dfd8;--border2:#cccbc2;--text:#1a1a18;--text2:#6b6a62;--text3:#9b9a92;--font:'IBM Plex Sans',sans-serif;--mono:'IBM Plex Mono',monospace;--radius:8px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:14px;min-height:100vh}
.login-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:999}
.login-box{width:100%;max-width:380px;padding:48px 40px;border:1px solid var(--border);border-radius:var(--radius);background:var(--surface);box-shadow:0 4px 24px rgba(0,0,0,.08)}
.login-logo{font-family:var(--mono);font-size:11px;color:var(--text2);letter-spacing:.15em;text-transform:uppercase;margin-bottom:32px}
.login-title{font-size:22px;font-weight:600;margin-bottom:6px}
.login-sub{font-size:13px;color:var(--text2);margin-bottom:32px}
.login-box input{width:100%;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius);padding:13px 16px;font-size:15px;font-family:var(--font);color:var(--text);margin-bottom:12px;transition:border-color .15s}
.login-box input:focus{outline:none;border-color:var(--text)}
.login-box button{width:100%;background:var(--text);color:#fff;border:none;border-radius:var(--radius);padding:13px;font-size:14px;font-weight:600;font-family:var(--font);cursor:pointer}
.login-box button:hover{opacity:.88}
.login-err{font-size:12px;color:#7a1a1a;margin-top:10px;display:none}
.login-err.show{display:block}
.app{display:none}.app.visible{display:block}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.topbar-brand{font-family:var(--mono);font-size:13px;color:var(--text2)}
.topbar-brand strong{color:var(--text);font-weight:600}
.topbar-right{display:flex;align-items:center;gap:16px}
.conn-dot{width:7px;height:7px;border-radius:50%;background:var(--border2)}
.conn-dot.ok{background:#3a8c3a}.conn-dot.err{background:#c0392b}
.conn-dot.spin{background:#c07000;animation:pulse .8s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.topbar-lbl{font-size:12px;color:var(--text2);font-family:var(--mono)}
.main{max-width:1280px;margin:0 auto;padding:28px 24px}
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;padding:16px 20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);align-items:flex-end}
.filter-group{display:flex;flex-direction:column;gap:5px;flex:1;min-width:130px}
.filter-group label{font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3)}
.filter-group input,.filter-group select{background:var(--surface);border:1px solid var(--border2);border-radius:6px;padding:9px 12px;font-size:13px;font-family:var(--font);color:var(--text);-webkit-appearance:none;transition:border-color .15s}
.filter-group input:focus,.filter-group select:focus{outline:none;border-color:var(--text)}
.btn{border-radius:6px;padding:9px 18px;font-size:13px;font-weight:500;font-family:var(--font);cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text);white-space:nowrap;transition:all .15s}
.btn:hover{background:var(--surface3)}
.btn-accent{background:var(--text);color:#fff;border-color:var(--text)}
.btn-accent:hover{opacity:.88}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px 22px;position:relative;overflow:hidden}
.kpi-card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px}
.kpi-card.k1::before{background:#3a8c3a}.kpi-card.k2::before{background:#1a4a7a}
.kpi-card.k3::before{background:#c07000}.kpi-card.k4::before{background:#c0392b}
.kpi-label{font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:10px}
.kpi-val{font-size:32px;font-weight:300;letter-spacing:-.5px;line-height:1;margin-bottom:6px}
.kpi-card.k1 .kpi-val{color:#2d6a2d}.kpi-card.k2 .kpi-val{color:#1a4a7a}
.kpi-card.k3 .kpi-val{color:#c07000}.kpi-card.k4 .kpi-val{color:#c0392b}
.kpi-sub{font-size:12px;color:var(--text2)}
.charts-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:24px}
@media(max-width:1000px){.charts-grid{grid-template-columns:1fr 1fr}}
@media(max-width:650px){.charts-grid{grid-template-columns:1fr}}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px 22px}
.chart-title{font-size:11px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:16px}
.chart-wrap{position:relative;height:200px}
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.table-head{display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border);gap:12px;flex-wrap:wrap}
.table-head-title{font-size:11px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3)}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3);padding:10px 16px;border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:12px 16px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-family:var(--mono)}
.b-ok{background:#e8f4e8;color:#2d6a2d;border:1px solid #b8ddb8}
.b-mid{background:#fdf3dc;color:#7a4f00;border:1px solid #e8d8a8}
.b-low{background:#f0efe9;color:#6b6a62;border:1px solid #e0dfd8}
.empty-table{text-align:center;padding:60px 20px;color:var(--text3);font-family:var(--mono);font-size:13px}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;overflow-y:auto;padding:24px}
.overlay.open{display:block}
.modal{max-width:820px;margin:0 auto;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:28px;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px;gap:12px;flex-wrap:wrap}
.modal-title{font-size:15px;font-weight:600}
.modal-num{font-family:var(--mono);font-size:12px;color:var(--text2);margin-bottom:4px}
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
@media(max-width:600px){.info-grid{grid-template-columns:1fr 1fr}}
.info-cell{font-size:11px;color:var(--text3);font-family:var(--mono);text-transform:uppercase;letter-spacing:.06em}
.info-cell strong{display:block;font-size:13px;color:var(--text);font-weight:500;margin-top:4px;font-family:var(--font);text-transform:none;letter-spacing:0}
.sec-title{font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.modal-section{margin-bottom:18px}
.modal table{font-size:13px}
.modal th{font-size:10px;padding:7px 12px}
.modal td{padding:9px 12px}
.note-box{background:var(--surface2);border-radius:6px;padding:12px 14px;font-size:13px;color:var(--text);line-height:1.6;border:1px solid var(--border)}
.tot-row{display:flex;gap:24px;justify-content:flex-end;padding:10px 12px 0;font-size:13px;color:var(--text2);border-top:1px solid var(--border);margin-top:4px}
.tot-row strong{color:#1a4a7a;font-weight:500}
.alert{padding:12px 16px;border-radius:6px;font-size:13px;margin-bottom:20px;display:none}
.alert.show{display:block}
.alert-err{background:#fae8e8;color:#7a1a1a;border:1px solid #e8b8b8}
.alert-ok{background:#e8f4e8;color:#2d6a2d;border:1px solid #b8ddb8}
.operai-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400;overflow-y:auto;padding:24px}
.operai-overlay.open{display:block}
.operai-modal{max-width:500px;margin:0 auto;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:28px;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.operaio-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:14px}
.operaio-item:last-child{border-bottom:none}
.operaio-del{background:none;border:none;color:#c0392b;cursor:pointer;font-size:18px;padding:2px 8px}
.operaio-del:hover{background:#fae8e8;border-radius:4px}
.modifica-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;overflow-y:auto;padding:24px}
.modifica-overlay.open{display:block}
.modifica-modal{max-width:700px;margin:0 auto;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:28px;box-shadow:0 8px 32px rgba(0,0,0,.12)}
.mod-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.mod-fg{display:flex;flex-direction:column;gap:5px}
.mod-fg label{font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3)}
.mod-fg input,.mod-fg select,.mod-fg textarea{background:var(--surface);border:1px solid var(--border2);border-radius:6px;padding:9px 12px;font-size:13px;font-family:var(--font);color:var(--text)}
.mod-fg textarea{min-height:70px;resize:vertical}
.mod-full{grid-column:1/-1}
.mod-op-row{display:flex;gap:8px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.mod-op-row:last-child{border-bottom:none}
@media print{.topbar,.filter-bar,.kpi-grid,.charts-grid,.table-card,.overlay,.login-screen,#alert{display:none!important}.modal{box-shadow:none;border:none;max-width:100%;padding:0}body{background:#fff}}
</style>
</head>
<body>
<div class="login-screen" id="login-screen">
  <div class="login-box">
    <div class="login-logo">&#9672; Rapportini</div>
    <div class="login-title">Dashboard responsabile</div>
    <div class="login-sub">Accesso riservato al supervisore</div>
    <input type="password" id="pwd" placeholder="Password">
    <button onclick="doLogin()">Accedi</button>
    <div class="login-err" id="pwd-err">Password non corretta.</div>
  </div>
</div>
<div class="app" id="app">
  <div class="topbar">
    <div class="topbar-brand">&#9672; <strong>TC Sistem</strong> Dashboard</div>
    <div class="topbar-right">
      <div class="conn-dot" id="conn-dot"></div>
      <span class="topbar-lbl" id="conn-lbl">&#8212;</span>
      <span class="topbar-lbl" id="refresh-countdown" style="color:var(--text3)"></span>
      <button class="btn" style="padding:5px 12px;font-size:12px" onclick="caricaDati()">&#8635;</button>
      <button class="btn" style="padding:5px 12px;font-size:12px" onclick="reindex()" title="Ricostruisci indice da Drive">🔧</button>
      <button class="btn" style="padding:5px 12px;font-size:12px" onclick="apriGestioneOperai()">👷 Operai</button>
      <a href="costi.html" style="padding:5px 12px;font-size:12px;background:var(--text);color:#fff;border-radius:6px;text-decoration:none;font-weight:500">💰 Costi</a>
    </div>
  </div>
  <div class="main">
    <div class="alert" id="alert"></div>
    <div class="filter-bar">
      <div class="filter-group" style="flex:none;min-width:110px"><label>Da</label><input type="date" id="f-da"></div>
      <div class="filter-group" style="flex:none;min-width:110px"><label>A</label><input type="date" id="f-a"></div>
      <div class="filter-group"><label>Tecnico</label><input type="text" id="f-tecnico" placeholder="Tutti..."></div>
      <div class="filter-group"><label>Cliente</label><input type="text" id="f-cliente" placeholder="Tutti..."></div>
      <div class="filter-group"><label>Commessa</label><input type="text" id="f-commessa" placeholder="Tutti..."></div>
      <div class="filter-group" style="flex:none;min-width:130px"><label>Stato</label>
        <select id="f-stato"><option value="">Tutti</option><option value="100">Completati</option><option value="&lt;100">In corso</option></select>
      </div>
      <div style="display:flex;gap:8px;align-items:flex-end">
        <button class="btn" onclick="aggiornaFiltri()">Filtra</button>
        <button class="btn" onclick="resetFiltri()">Reset</button>
        <button class="btn btn-accent" onclick="caricaDati()">Aggiorna</button>
      </div>
    </div>
    <div class="kpi-grid">
      <div class="kpi-card k1"><div class="kpi-label">Rapportini</div><div class="kpi-val" id="kpi-tot">&#8212;</div><div class="kpi-sub" id="kpi-tot-sub">&#8212;</div></div>
      <div class="kpi-card k2"><div class="kpi-label">Ore lavoro</div><div class="kpi-val" id="kpi-lav">&#8212;</div><div class="kpi-sub" id="kpi-lav-sub">&#8212;</div></div>
      <div class="kpi-card k3"><div class="kpi-label">Ore viaggio</div><div class="kpi-val" id="kpi-viag">&#8212;</div><div class="kpi-sub" id="kpi-viag-sub">&#8212;</div></div>
      <div class="kpi-card k4"><div class="kpi-label">Ore straord.</div><div class="kpi-val" id="kpi-str">&#8212;</div><div class="kpi-sub" id="kpi-str-sub">&#8212;</div></div>
    </div>
    <div class="charts-grid" style="grid-template-columns:1fr 1fr">
      <div class="chart-card"><div class="chart-title">Ore lavoro per commessa</div><div class="chart-wrap"><canvas id="chart-tecnici"></canvas></div></div>
      <div class="chart-card"><div class="chart-title">Riepilogo ore per tipo</div><div class="chart-wrap"><canvas id="chart-tipo"></canvas></div></div>
    </div>
    <div class="table-card">
      <div class="table-head">
        <div class="table-head-title" id="table-count">&#8212; rapportini</div>
        <button class="btn" onclick="esportaCSV()">Esporta CSV</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>N.</th><th>Data</th><th>Cliente</th><th>Commessa</th><th>Tecnico</th><th>Tipo</th><th style="text-align:right">Lav.</th><th style="text-align:right">Viag.</th><th style="text-align:right">Str.</th><th>Stato</th></tr></thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="overlay" id="overlay" onclick="if(event.target===this)chiudiModale()">
  <div class="modal">
    <div class="modal-head">
      <div><div class="modal-num" id="mod-num">&#8212;</div><div class="modal-title" id="mod-title">&#8212;</div></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-accent" onclick="stampaPdfModale()">Stampa PDF</button>
        <button class="btn" onclick="inviaMailCliente()">Invia al cliente</button>
        <button class="btn" onclick="apriModificaModale()">✏️ Modifica</button>
        <button class="btn" onclick="esportaDettaglioCSV()">CSV</button>
        <button class="btn" onclick="chiudiModale()">Chiudi</button>
      </div>
    </div>
    <div id="mod-body"></div>
  </div>
</div>
<!-- MODALE MODIFICA -->
<div class="modifica-overlay" id="modifica-overlay" onclick="if(event.target===this)chiudiModifica()">
  <div class="modifica-modal">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <div style="font-size:16px;font-weight:600">✏️ Modifica Rapportino</div>
      <button class="btn" onclick="chiudiModifica()">Chiudi</button>
    </div>
    <div class="mod-grid">
      <div class="mod-fg"><label>N. Rapportino</label><input type="text" id="mod-f-num" readonly style="background:var(--surface2);color:var(--text2)"></div>
      <div class="mod-fg"><label>Data</label><input type="date" id="mod-f-data"></div>
      <div class="mod-fg"><label>Cliente</label><input type="text" id="mod-f-cliente"></div>
      <div class="mod-fg"><label>N. Commessa</label><input type="text" id="mod-f-commessa"></div>
      <div class="mod-fg"><label>Indirizzo</label><input type="text" id="mod-f-indirizzo"></div>
      <div class="mod-fg"><label>Tecnico</label><input type="text" id="mod-f-tecnico" oninput="this.value=this.value.toUpperCase()" style="text-transform:uppercase"></div>
      <div class="mod-fg"><label>Tipo</label>
        <select id="mod-f-tipo">
          <option value="">Seleziona...</option>
          <option>Manutenzione ordinaria</option>
          <option>Manutenzione straordinaria</option>
          <option>Installazione</option><option>Riparazione</option>
          <option>Collaudo</option><option>Ispezione</option><option>Altro</option>
        </select>
      </div>
      <div class="mod-fg"><label>Avanzamento</label>
        <select id="mod-f-stato">
          <option value="0">0%</option><option value="25">25%</option>
          <option value="50">50%</option><option value="75">75%</option>
          <option value="100">100%</option>
        </select>
      </div>
      <div class="mod-fg mod-full"><label>Descrizione</label><textarea id="mod-f-desc"></textarea></div>
      <div class="mod-fg mod-full"><label>Note</label><textarea id="mod-f-note"></textarea></div>
    </div>
    <div style="font-size:10px;font-family:var(--mono);text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:10px">Operai e ore</div>
    <div id="mod-operai-lista" style="margin-bottom:14px"></div>
    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
      <select id="mod-op-nome" style="flex:1;min-width:150px;border:1px solid var(--border2);border-radius:6px;padding:8px 12px;font-size:13px;font-family:var(--font)">
        <option value="">Seleziona operaio...</option>
      </select>
      <input type="number" id="mod-op-lav" placeholder="Lav." min="0" step="0.5" style="width:80px;border:1px solid var(--border2);border-radius:6px;padding:8px;font-size:13px">
      <input type="number" id="mod-op-viag" placeholder="Viag." min="0" step="0.5" style="width:80px;border:1px solid var(--border2);border-radius:6px;padding:8px;font-size:13px">
      <input type="number" id="mod-op-str" placeholder="Str." min="0" step="0.5" style="width:80px;border:1px solid var(--border2);border-radius:6px;padding:8px;font-size:13px">
      <button class="btn" onclick="modAddOp()" style="padding:8px 14px">+ Aggiungi</button>
    </div>
    <div style="margin-top:16px;display:flex;justify-content:flex-end;gap:8px">
      <button class="btn" onclick="chiudiModifica()">Annulla</button>
      <button class="btn btn-accent" onclick="salvaModifica()">💾 Salva e aggiorna su Drive</button>
    </div>
  </div>
</div>

<!-- MODALE OPERAI -->
<div class="operai-overlay" id="operai-overlay" onclick="if(event.target===this)chiudiGestioneOperai()">
  <div class="operai-modal">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <div style="font-size:16px;font-weight:600">👷 Gestione Operai</div>
      <button class="btn" onclick="chiudiGestioneOperai()">Chiudi</button>
    </div>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px">Gli operai inseriti qui appariranno nell'autocomplete del rapportino.</p>
    <div style="display:flex;gap:8px;margin-bottom:16px">
      <input type="text" id="nuovo-operaio" placeholder="NOME E COGNOME" 
        style="flex:1;text-transform:uppercase"
        oninput="this.value=this.value.toUpperCase()"
        onkeydown="if(event.key==='Enter')aggiungiOperaio()">
      <button class="btn btn-accent" onclick="aggiungiOperaio()">+ Aggiungi</button>
    </div>
    <div id="operai-lista"><div style="text-align:center;padding:20px;color:var(--text3)">Caricamento...</div></div>
    <div style="margin-top:16px;display:flex;justify-content:flex-end">
      <button class="btn btn-accent" onclick="salvaOperai()">💾 Salva lista</button>
    </div>
  </div>
</div>

<script>
var SCRIPT_URL    = 'https://script.google.com/macros/s/AKfycbw1JPZ5HKLG50ywH1dFzLUPGVwn_wnVFcwEJDyjM08N1tICGHNAqSXz1ZW-91w2wdBF/exec';
var DASH_PASSWORD = 'TCSResp2025!';
var REFRESH_MIN   = 210;
var tutti = [], filtrati = [], rapCorrente = null, charts = {};
var refreshTimer = null, countdownTimer = null, secondiRimasti = 0;
